<?xml version="1.0" encoding="UTF-8"?>
<module rename-to="html">
	<!-- The GWT launcher lives in angry.birds.gwt -->
	<source path="gwt" />

	<inherits name="jsinterop.annotations.Annotations" />
	<inherits name="com.badlogic.gdx.backends.gdx_backends_gwt" />
	<inherits name="angry.birds.GameCore" />
	<inherits name="com.badlogic.gdx.physics.box2d.box2d-gwt" />

	<entry-point class="angry.birds.gwt.GwtLauncher" />

	<!-- Where the game assets live, relative to this html module. -->
	<set-configuration-property name="gdx.assetpath" value="../assets" />
	<set-configuration-property name="xsiframe.failIfScriptTag" value="FALSE" />

	<!-- Only compile a single browser permutation to speed up the build.
	     Modern browsers all report as "safari" (webkit) here. -->
	<set-property name="user.agent" value="safari" />
</module>
